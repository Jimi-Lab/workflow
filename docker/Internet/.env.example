# VulnVersion Internet Docker runtime template
# Copy this to a runtime .env file and pass it with:
#   docker run --env-file my-runtime.env ...

CONDA_ENV_NAME=VulnVersion
OPENCODE_HOST=127.0.0.1
OPENCODE_PORT=4096

# Optional runtime defaults
# VV_REPOS=curl
VV_DATASET=DataSet/BaseDataTest.json

# Default example: generic OpenAI-compatible endpoint
OPENCODE_PROVIDER_ID=local-openai
OPENCODE_MODEL_ID=your-model-name
OPENAI_MODEL=your-model-name

# On Docker Desktop, host.docker.internal usually works.
# On Linux Docker, replace with a reachable host IP or service DNS.
OPENAI_BASE_URL=http://host.docker.internal:8000/v1
OPENAI_API_KEY=dummy

# Example: MiniMax local provider
# OPENCODE_PROVIDER_ID=minimaxlocal
# OPENCODE_MODEL_ID=MiniMax-M2.5
# MINIMAXLOCAL_BASE_URL=http://your-host:3333/v1
# MINIMAXLOCAL_API_KEY=your-key

# Example: XiaoAiPlus provider
# OPENCODE_PROVIDER_ID=xiaoaiplus
# OPENCODE_MODEL_ID=gpt-5.4
# XIAOAIPLUS_BASE_URL=https://xiaoai.plus/v1/
# XIAOAIPLUS_API_KEY=your-key

# Example: C402 local provider
# OPENCODE_PROVIDER_ID=c402
# OPENCODE_MODEL_ID=glm-5.1-fp8
# C402_BASE_URL=http://your-host:33330/v1
# C402_API_KEY=your-key
