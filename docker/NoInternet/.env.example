# Copy this file to ".env" inside the container or pass the same keys via
# `docker run --env-file ...`.
#
# For the bundled offline image, the recommended path is a local or LAN-reachable
# OpenAI-compatible endpoint.

CONDA_ENV_NAME=VulnVersion
OPENCODE_HOST=127.0.0.1
OPENCODE_PORT=4096

# VulnVersion client-side model selection
OPENCODE_PROVIDER_ID=local-openai
OPENCODE_MODEL_ID=your-model-name
OPENAI_MODEL=your-model-name

# Provider endpoint / credential
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_API_KEY=dummy
