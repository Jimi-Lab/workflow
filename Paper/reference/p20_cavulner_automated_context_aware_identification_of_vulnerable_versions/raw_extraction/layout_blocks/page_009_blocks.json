  {
    "page": 9,
    "block_id": "page_009:block_050",
    "block_type": "text",
    "text": "CaVulner : Automated Context-Aware Identification of Vulnerable Versions 9",
    "bbox": [
      45.827999114990234,
      60.60470199584961,
      440.1680908203125,
      69.88189697265625
    ],
