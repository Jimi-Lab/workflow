    "block_id": "p09_v_szz_automatic_identification_version_ranges_2022:block:005:030",
    "block_type": "text",
    "text": "Figure 4: Two commits in the project OpenSSL with the same\nchange\n",
    "bbox": [
      53.79800033569336,
      381.4244689941406,
      294.032958984375,
      404.41583251953125
