{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "local-openai": {
      "name": "Local OpenAI-Compatible",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "your-model-name": {
          "name": "Runtime-selected local model"
        }
      },
      "options": {
        "baseURL": "{env:OPENAI_BASE_URL}",
        "apiKey": "{env:OPENAI_API_KEY}"
      }
    },
    "minimaxlocal": {
      "name": "MiniMax-402",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "MiniMax-M2.5": {
          "name": "MiniMax M2.5"
        }
      },
      "options": {
        "baseURL": "{env:MINIMAXLOCAL_BASE_URL}",
        "apiKey": "{env:MINIMAXLOCAL_API_KEY}"
      }
    },
    "xiaoaiplus": {
      "name": "XiaoAiPlus",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4"
        },
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro"
        },
        "claude-sonnet-4-6": {
          "name": "Claude 4.6 Sonnet"
        },
        "deepseek-v3.1-thinking": {
          "name": "DeepSeek V3.1 Thinking"
        }
      },
      "options": {
        "baseURL": "{env:XIAOAIPLUS_BASE_URL}",
        "apiKey": "{env:XIAOAIPLUS_API_KEY}"
      }
    },
    "c402": {
      "name": "glm-5.1-fp8",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "glm-5.1-fp8": {
          "name": "glm-5.1-fp8"
        }
      },
      "options": {
        "baseURL": "{env:C402_BASE_URL}",
        "apiKey": "{env:C402_API_KEY}"
      }
    }
  },
  "agent": {},
  "mode": {},
  "plugin": [],
  "command": {}
}
