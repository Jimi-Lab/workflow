  "CVE-2020-22019": [
    {
      "file_patterns": [
        "libavfilter/vf_vmafmotion.c"
      ],
      "function_patterns": [
        "ff_vmafmotion_init",
        "convolution_y_10bit",
        "convolution_y_8bit",
        "convolution_x",
        "ff_vmafmotion_process"
      ],
      "vulnerable_tokens": [
        "s->width = w;",
        "s->height = h;",
        "s->stride = FFALIGN(w * sizeof(uint16_t), 32);",
        "borders_right = w - (filt_w - radius)",
        "borders_bottom = h - (filt_w - radius)"
      ],
      "fix_tokens": [
        "if (w < 3 || h < 3)",
        "return AVERROR(EINVAL);"
      ],
      "grep_patterns": [
        "s->width\\s*=\\s*w\\s*;",
        "borders_right\\s*=",
        "convolution_y_10bit",
        "ff_vmafmotion_init"
      ],
      "line_risk_signals": [
        "ff_vmafmotion_init stores caller-supplied dimensions without validation",
        "convolution loop bounds become negative when dimensions < filter radius*2+1",
        "Edge-clamp formula produces negative index for j_tap >> w"
      ]
    }
  ],
