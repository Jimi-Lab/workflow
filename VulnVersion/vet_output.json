    "vulnerable_condition": {
      "necessary_conditions": [
        "The dissector is invoked on a tvbuff that ends before (or exactly at) the offset being processed in any of the three loops",
        "The `tvb_find_line_end` call uses `reassembly=FALSE` (last parameter) at all three loop sites — guaranteeing zero-length return without next_offset advancement when past end",
        "The loop must be an unconditional `for (;;)` with no exit condition on offset bounds — all three loops match this"
      ],
      "vulnerable_sequences": [
